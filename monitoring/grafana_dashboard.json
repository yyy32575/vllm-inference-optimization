{
  "annotations": {
    "list": []
  },
  "description": "VLLM Inference Optimization Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Throughput (tokens/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "vllm_opt_throughput_tokens_per_sec",
          "legendFormat": "Throughput"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "tok/s"
        }
      }
    },
    {
      "title": "Request Latency (P50/P95/P99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(vllm_opt_request_latency_ms_bucket{phase=\"total\"}[5m]))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(vllm_opt_request_latency_ms_bucket{phase=\"total\"}[5m]))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(vllm_opt_request_latency_ms_bucket{phase=\"total\"}[5m]))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "title": "Time to First Token",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(vllm_opt_ttft_ms_bucket[5m]))",
          "legendFormat": "P50 TTFT"
        },
        {
          "expr": "histogram_quantile(0.95, rate(vllm_opt_ttft_ms_bucket[5m]))",
          "legendFormat": "P95 TTFT"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "title": "GPU Utilization",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "vllm_opt_gpu_utilization",
          "legendFormat": "GPU {{gpu_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 0.7},
              {"color": "red", "value": 0.9}
            ]
          }
        }
      }
    },
    {
      "title": "GPU Memory Usage",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
      "targets": [
        {
          "expr": "vllm_opt_gpu_memory_used_gb",
          "legendFormat": "GPU {{gpu_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes"
        }
      }
    },
    {
      "title": "Prefill vs Decode Latency",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(vllm_opt_request_latency_ms_bucket{phase=\"prefill\"}[5m]))",
          "legendFormat": "P95 Prefill"
        },
        {
          "expr": "histogram_quantile(0.95, rate(vllm_opt_request_latency_ms_bucket{phase=\"decode\"}[5m]))",
          "legendFormat": "P95 Decode"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "title": "SLO Compliance",
      "type": "stat",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "vllm_opt_slo_compliance_ratio",
          "legendFormat": "Compliance"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              {"color": "red", "value": 0},
              {"color": "yellow", "value": 0.9},
              {"color": "green", "value": 0.99}
            ]
          }
        }
      }
    },
    {
      "title": "Request Rate & Errors",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 16},
      "targets": [
        {
          "expr": "rate(vllm_opt_requests_total{status=\"success\"}[5m])",
          "legendFormat": "Success"
        },
        {
          "expr": "rate(vllm_opt_requests_total{status=\"error\"}[5m])",
          "legendFormat": "Error"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    }
  ],
  "schemaVersion": 38,
  "tags": ["vllm", "inference", "optimization"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "VLLM Inference Optimization",
  "uid": "vllm-inference-opt"
}
